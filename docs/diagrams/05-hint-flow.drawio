<mxfile host="app.diagrams.net">
  <diagram id="hint-flow" name="Hint and Q&amp;A Flow">
    <mxGraphModel dx="1000" dy="700" grid="0" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1560" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="Hint system — two grounded paths into the lesson caption" style="text;html=1;fontSize=20;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="800" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="path1" value="Path 1 — step hints (streamed with every lesson step)" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fontSize=13;fontStyle=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="1480" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="p1a" value="Planner builds step&#10;(exact moves known)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#ffffff;strokeColor=#82b366;" vertex="1" parent="path1">
          <mxGeometry x="30" y="60" width="220" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="p1b" value="Qwen narrates the frame&#10;→ FrameNarration.hints&#10;(validated against frame moves)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="path1">
          <mxGeometry x="380" y="60" width="260" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="p1c" value="SSE step event&#10;{title, body, hints[], moves}" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#ffffff;strokeColor=#82b366;" vertex="1" parent="path1">
          <mxGeometry x="770" y="60" width="240" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="p1d" value="StageCaption hint box&#10;(shown under the step body)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="path1">
          <mxGeometry x="1140" y="60" width="240" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="pe1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="path1" source="p1a" target="p1b"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="pe2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="path1" source="p1b" target="p1c"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="pe3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="path1" source="p1c" target="p1d"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="path2" value="Path 2 — Ask Qwen (on-demand, mid-step)" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fontSize=13;fontStyle=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="40" y="320" width="1480" height="240" as="geometry"/>
        </mxCell>
        <mxCell id="p2a" value="&quot;Ask Qwen about this step…&quot;&#10;input in StageCaption&#10;(any active lesson / drill / walkthrough)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="path2">
          <mxGeometry x="30" y="60" width="260" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="p2b" value="POST /ask&#10;{question, facelets, level,&#10;current step context}" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="path2">
          <mxGeometry x="380" y="60" width="240" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="p2c" value="answer_question — grounded prompt:&#10;live cube state + step moves included,&#10;so answers reference the real cube" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="path2">
          <mxGeometry x="710" y="60" width="280" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="p2d" value="Answer rendered inline&#10;under the Ask box" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="path2">
          <mxGeometry x="1140" y="60" width="240" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="p2note" value="Backend down? Both paths degrade gracefully: streamed steps fall back to deterministic template text,&#10;Ask shows an inline &quot;Couldn&#39;t ask&quot; error — the lesson itself keeps working." style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacing=8;" vertex="1" parent="path2">
          <mxGeometry x="30" y="160" width="960" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="qe1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="path2" source="p2a" target="p2b"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="qe2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="path2" source="p2b" target="p2c"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="qe3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="path2" source="p2c" target="p2d"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="chk" value="Related: checkpoints — every lesson step keeps a cube-state checkpoint; &quot;Back to checkpoint&quot; (StageCaption) and &quot;Reset to checkpoint&quot; (demo window) restore it, so experimenting mid-lesson is always safe." style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#f8cecc;strokeColor=#b85450;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="600" width="1480" height="60" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
