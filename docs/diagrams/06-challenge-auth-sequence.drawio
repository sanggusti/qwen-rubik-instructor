<mxfile host="app.diagrams.net">
  <diagram id="chal-seq" name="Challenge and Auth Sequence">
    <mxGraphModel dx="1000" dy="700" grid="0" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1560" pageHeight="1240" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="Challenge Me — Google sign-in and a leaderboard with a server-side clock" style="text;html=1;fontSize=20;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="900" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="lb" value="Browser (/play)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;fontStyle=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="180" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="lf" value="FastAPI backend" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;fontStyle=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="560" y="80" width="180" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="lg" value="Google OAuth" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;fontStyle=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="1020" y="80" width="180" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="lt" value="Turso / libSQL" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;fontStyle=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="1320" y="80" width="180" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="ll1" style="endArrow=none;dashed=1;html=1;strokeColor=#6c8ebf;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="150" y="130" as="sourcePoint"/><mxPoint x="150" y="1200" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ll2" style="endArrow=none;dashed=1;html=1;strokeColor=#82b366;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="650" y="130" as="sourcePoint"/><mxPoint x="650" y="1200" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ll3" style="endArrow=none;dashed=1;html=1;strokeColor=#d79b00;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1110" y="130" as="sourcePoint"/><mxPoint x="1110" y="1200" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ll4" style="endArrow=none;dashed=1;html=1;strokeColor=#b85450;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1410" y="130" as="sourcePoint"/><mxPoint x="1410" y="1200" as="targetPoint"/></mxGeometry></mxCell>

        <mxCell id="sec1" value="sign in (authorization-code flow)" style="text;html=1;fontSize=13;fontStyle=2;align=left;fontColor=#666666;" vertex="1" parent="1"><mxGeometry x="60" y="150" width="400" height="20" as="geometry"/></mxCell>
        <mxCell id="a1" value="click ⚡ Challenge Me (no token) → GET /auth/google" style="html=1;fontSize=12;endArrow=block;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="150" y="190" as="sourcePoint"/><mxPoint x="650" y="190" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="a2" value="302 → consent screen (scope: openid email)" style="html=1;fontSize=12;endArrow=block;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="650" y="240" as="sourcePoint"/><mxPoint x="1110" y="240" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="a3" value="redirect: GET /auth/callback?code=…" style="html=1;fontSize=12;endArrow=block;dashed=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1110" y="290" as="sourcePoint"/><mxPoint x="650" y="290" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="a4" value="exchange code → access token → userinfo (sub, email)" style="html=1;fontSize=12;endArrow=block;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="650" y="340" as="sourcePoint"/><mxPoint x="1110" y="340" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="a5" value="upsert members(id = google sub) · mint opaque UUID token (30-day, auth_tokens)" style="html=1;fontSize=12;endArrow=block;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="650" y="390" as="sourcePoint"/><mxPoint x="1410" y="390" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="a6" value="302 → /play?token=… → layout strips URL, stores in localStorage[rubik-auth-token]" style="html=1;fontSize=12;endArrow=block;dashed=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="650" y="440" as="sourcePoint"/><mxPoint x="150" y="440" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="a7" value="POST /auth/username (first time — shows on the leaderboard, unique, 409 if taken)" style="html=1;fontSize=12;endArrow=block;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="150" y="490" as="sourcePoint"/><mxPoint x="650" y="490" as="targetPoint"/></mxGeometry></mxCell>

        <mxCell id="sec2" value="timed run (server-side clock — client never reports its own time)" style="text;html=1;fontSize=13;fontStyle=2;align=left;fontColor=#666666;" vertex="1" parent="1"><mxGeometry x="60" y="540" width="600" height="20" as="geometry"/></mxCell>
        <mxCell id="b1" value="POST /challenge/start (Bearer)" style="html=1;fontSize=12;endArrow=block;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="150" y="580" as="sourcePoint"/><mxPoint x="650" y="580" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="b2" value="INSERT challenge_sessions {key, started_at, expires +1 h}" style="html=1;fontSize=12;endArrow=block;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="650" y="630" as="sourcePoint"/><mxPoint x="1410" y="630" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="b3" value="{key, startedAt} — client scrambles (20 moves) and shows timer HUD" style="html=1;fontSize=12;endArrow=block;dashed=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="650" y="680" as="sourcePoint"/><mxPoint x="150" y="680" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="anti" value="Anti-cheat while running: rail hides Scramble/Reset/Guide — only timer + &quot;Give Up!&quot;.&#10;Reset or Scramble via any other path cancels the run (Reset would otherwise be an instant win)." style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacing=8;" vertex="1" parent="1"><mxGeometry x="200" y="720" width="620" height="65" as="geometry"/></mxCell>
        <mxCell id="b4" value="cube solved (or Give Up) → POST /challenge/score {key, status} (Bearer)" style="html=1;fontSize=12;endArrow=block;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="150" y="830" as="sourcePoint"/><mxPoint x="650" y="830" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="b5" value="atomic UPDATE…RETURNING marks key used · solve_time_ms = now − started_at&#10;INSERT challenge_scores {username, solve_time_ms, status}" style="html=1;fontSize=12;endArrow=block;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="650" y="890" as="sourcePoint"/><mxPoint x="1410" y="890" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="b6" value="{solveTimeMs, bestMs} → confetti + leaderboard modal" style="html=1;fontSize=12;endArrow=block;dashed=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="650" y="950" as="sourcePoint"/><mxPoint x="150" y="950" as="targetPoint"/></mxGeometry></mxCell>

        <mxCell id="sec3" value="public leaderboard" style="text;html=1;fontSize=13;fontStyle=2;align=left;fontColor=#666666;" vertex="1" parent="1"><mxGeometry x="60" y="1000" width="400" height="20" as="geometry"/></mxCell>
        <mxCell id="c1" value="GET /challenge/leaderboard (no auth — landing page + modal)" style="html=1;fontSize=12;endArrow=block;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="150" y="1040" as="sourcePoint"/><mxPoint x="650" y="1040" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="c2" value="solved first (fastest asc), then give-up entries" style="html=1;fontSize=12;endArrow=block;dashed=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="650" y="1100" as="sourcePoint"/><mxPoint x="150" y="1100" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="kn" value="Kill switch: persistence or Google OAuth unconfigured ⇒ /auth/* and /challenge/* return 503; the landing leaderboard section silently hides." style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacing=8;" vertex="1" parent="1"><mxGeometry x="60" y="1140" width="800" height="50" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
