<mxfile host="app.diagrams.net">
  <diagram id="phys-comp" name="Component View">
    <mxGraphModel dx="1000" dy="700" grid="0" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1560" pageHeight="880" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="Physical Cube Play — Camera Scan Pipeline (component view, post-audit)" style="text;html=1;fontSize=20;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="760" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="user" value="Learner + physical cube" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="70" y="330" width="50" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="browser" value="Browser — SvelteKit frontend (frontend/)" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fontSize=14;fontStyle=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="200" y="90" width="700" height="620" as="geometry"/>
        </mxCell>
        <mxCell id="cam" value="PhysicalCameraWindow&#10;getUserMedia + 3×3 overlay&#10;SLEEPS between scan windows&#10;(playsinline/autoplay/muted; one stream)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="browser">
          <mxGeometry x="20" y="50" width="210" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="sampler" value="sampler.ts&#10;rVFC 2–5fps, ≤160px stillness diff;&#10;full-res + median ROI at capture only" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="browser">
          <mxGeometry x="20" y="160" width="210" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="classify" value="color-classify.ts&#10;RGB→LAB, CIEDE2000 vs 6 center anchors,&#10;k-means over 54, per-sticker confidence" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="browser">
          <mxGeometry x="20" y="250" width="210" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="legal" value="legality.ts&#10;cubie structure · twist ≡0 mod 3 ·&#10;flip ≡0 mod 2 · parity · rotation auto-fix" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="browser">
          <mxGeometry x="20" y="360" width="210" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="fsm" value="physicalStore + scan-machine.ts&#10;idle → scanning(6) → adjust → validating&#10;→ ready → guided: chunk ⟲ confirm&#10;(side: verify · explain-diff · repair)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#ffffff;strokeColor=#6c8ebf;fontStyle=1;" vertex="1" parent="browser">
          <mxGeometry x="20" y="470" width="210" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="infer" value="infer-moves.ts&#10;canonicalize centers · subset statesEqual&#10;· diff-explain BFS ≤2 from expected_state" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="browser">
          <mxGeometry x="290" y="360" width="190" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="cubestore" value="cubeStore (read-only mirror)&#10;loadState(state) + onLoadState (new)&#10;applyMoves(expected chunk) → onMove" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#ffffff;strokeColor=#6c8ebf;fontStyle=1;" vertex="1" parent="browser">
          <mxGeometry x="290" y="470" width="190" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="mirror" value="While physical mode active:&#10;inputs suppressed (keyboard/drag/pad);&#10;mirror renders ON-DEMAND only&#10;(autoInvalidate=false + invalidate())" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="browser">
          <mxGeometry x="290" y="250" width="190" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="demo" value="DemoCubeWindow = coach card&#10;primary visual: shows each&#10;3–6 move chunk (phone: mirror&#10;demoted to thumbnail)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="browser">
          <mxGeometry x="510" y="50" width="170" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="subs" value="Existing consumers&#10;&#10;lesson coaching — onMove&#10;(trailingPrefixLength)&#10;walkthrough — chunked beats;&#10;gate Solve-my-cube in physical&#10;review — recordSolve (unchanged)&#10;challenge — cancel on loadState" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#ffffff;strokeColor=#6c8ebf;verticalAlign=top;" vertex="1" parent="browser">
          <mxGeometry x="510" y="390" width="170" height="180" as="geometry"/>
        </mxCell>

        <mxCell id="backend" value="FastAPI backend (backend/)" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fontSize=14;fontStyle=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="960" y="90" width="540" height="620" as="geometry"/>
        </mxCell>
        <mxCell id="assist" value="POST /scan/assist (new, only Qwen-VL touchpoint)&#10;low-confidence cells + anchors →&#10;per-cell {color, confidence}, rate-limited" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#ffffff;strokeColor=#9673a6;" vertex="1" parent="backend">
          <mxGeometry x="30" y="60" width="230" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="qwenvl" value="Qwen-VL&#10;qwen3-vl-plus, JSON mode&#10;(DashScope compatible-mode)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="backend">
          <mxGeometry x="320" y="60" width="190" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="legpy" value="pipeline/cube/legality.py (new)&#10;verbatim TS mirror, Node↔Py cross-validated;&#10;hardens /solve + /narrate 4xx" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="backend">
          <mxGeometry x="30" y="220" width="230" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="solveapi" value="POST /solve · /narrate/* (existing)&#10;already accept a full State" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#ffffff;strokeColor=#9673a6;" vertex="1" parent="backend">
          <mxGeometry x="30" y="350" width="230" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="solver" value="LBL solver + planner (existing)&#10;start_from_current, invert(solution) as data,&#10;expected_state per stage → checkpoints" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="backend">
          <mxGeometry x="320" y="350" width="190" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="e1" style="endArrow=block;html=1;" edge="1" parent="1" source="user" target="cam">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e2" style="endArrow=block;html=1;" edge="1" parent="browser" source="cam" target="sampler">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e3" style="endArrow=block;html=1;" edge="1" parent="browser" source="sampler" target="classify">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e4" style="endArrow=block;html=1;" edge="1" parent="browser" source="classify" target="legal">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e5" style="endArrow=block;html=1;" edge="1" parent="browser" source="legal" target="fsm">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e6" value="full scan → loadState" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="browser" source="fsm" target="cubestore">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e7" value="checkpoint / check-me" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="browser" source="fsm" target="infer">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e8" value="chunk confirm → expected moves&#10;(rescue: inferred diff)" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="browser" source="infer" target="cubestore">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e9" value="onMove / onLoadState" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="browser" source="cubestore" target="subs">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e10" value="chunk playback" style="endArrow=block;html=1;fontSize=11;dashed=1;" edge="1" parent="browser" source="subs" target="demo">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e11" value="low-confidence cells only" style="endArrow=block;html=1;fontSize=11;dashed=1;" edge="1" parent="1" source="fsm" target="assist">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e12" style="endArrow=block;html=1;" edge="1" parent="backend" source="assist" target="qwenvl">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e13" value="generateWalkthrough({state}) — unchanged" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1" source="cubestore" target="solveapi">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e14" value="validate" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="backend" source="solveapi" target="legpy">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e15" style="endArrow=block;html=1;" edge="1" parent="backend" source="solveapi" target="solver">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="thesis" value="Post-audit model: scan once → trust-advance 3–6 move chunks (camera asleep) → optional per-stage 2-face checkpoint (subset statesEqual vs expected_state) → diff-explain BFS ≤2 only on 'check me' → repair ladder. Zero mandatory scans after onboarding. Perf: mirror on-demand rendering + sleeping camera; ~1–3ms/tick during scan windows only." style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="200" y="740" width="700" height="80" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="phys-seq" name="Guided Tracking Sequence">
    <mxGraphModel dx="1000" dy="700" grid="0" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1560" pageHeight="920" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="Guided Tracking — trust-advance chunks, checkpoint verify, repair (sequence)" style="text;html=1;fontSize=20;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="820" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="hLearner" value="Learner (physical cube)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fontStyle=1;fillColor=#ffffff;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="60" y="70" width="160" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="hCoach" value="Coach card + demo cube" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fontStyle=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="340" y="70" width="170" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="hCam" value="Camera + scan FSM (asleep by default)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fontStyle=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="640" y="70" width="190" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="hInfer" value="infer-moves.ts (compare / diff-explain)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fontStyle=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="960" y="70" width="190" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="hStore" value="cubeStore (mirror)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fontStyle=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="1280" y="70" width="160" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="lLearner" style="endArrow=none;dashed=1;html=1;strokeColor=#999999;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="140" y="110" as="sourcePoint"/><mxPoint x="140" y="880" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="lCoach" style="endArrow=none;dashed=1;html=1;strokeColor=#999999;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="425" y="110" as="sourcePoint"/><mxPoint x="425" y="880" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="lCam" style="endArrow=none;dashed=1;html=1;strokeColor=#999999;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="735" y="110" as="sourcePoint"/><mxPoint x="735" y="880" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="lInfer" style="endArrow=none;dashed=1;html=1;strokeColor=#999999;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1055" y="110" as="sourcePoint"/><mxPoint x="1055" y="880" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="lStore" style="endArrow=none;dashed=1;html=1;strokeColor=#999999;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1360" y="110" as="sourcePoint"/><mxPoint x="1360" y="880" as="targetPoint"/></mxGeometry>
        </mxCell>

        <mxCell id="loop1" value="guided chunk loop — default, camera asleep, zero scans" style="rounded=0;whiteSpace=wrap;html=1;fontSize=11;fontStyle=2;verticalAlign=top;align=left;spacing=6;dashed=1;fillColor=none;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="80" y="130" width="1360" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="m1" value="demo cube plays next 3–6 move chunk + big-type caption" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="425" y="170" as="sourcePoint"/><mxPoint x="140" y="170" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="n1" value="learner performs the chunk&#10;on the physical cube" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="60" y="195" width="170" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="m2" value="confirm — tap / space / big bottom target (audio tick)" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="140" y="265" as="sourcePoint"/><mxPoint x="425" y="265" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m3" value="applyMoves(expected chunk) → mirror animates, onMove events to coaching/lessons" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="425" y="310" as="sourcePoint"/><mxPoint x="1360" y="310" as="targetPoint"/></mxGeometry>
        </mxCell>

        <mxCell id="loop2" value="stage checkpoint — optional, ~7× per solve" style="rounded=0;whiteSpace=wrap;html=1;fontSize=11;fontStyle=2;verticalAlign=top;align=left;spacing=6;dashed=1;fillColor=none;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="80" y="370" width="1360" height="240" as="geometry"/>
        </mxCell>
        <mxCell id="m4" value="&quot;Show me your cube ✓&quot; → camera wakes (~200–500ms)" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="425" y="410" as="sourcePoint"/><mxPoint x="735" y="410" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m5" value="present 2 faces (green front, tip for white top) — auto-capture on stillness" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="140" y="460" as="sourcePoint"/><mxPoint x="735" y="460" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m6" value="18 classified stickers → subset statesEqual vs planner expected_state" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="735" y="510" as="sourcePoint"/><mxPoint x="1055" y="510" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m7" value="match → chime + confidence banner; camera back to sleep" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1055" y="560" as="sourcePoint"/><mxPoint x="425" y="560" as="targetPoint"/></mxGeometry>
        </mxCell>

        <mxCell id="loop3" value="check-me / repair ladder — on demand or checkpoint mismatch" style="rounded=0;whiteSpace=wrap;html=1;fontSize=11;fontStyle=2;verticalAlign=top;align=left;spacing=6;dashed=1;fillColor=none;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="80" y="630" width="1360" height="230" as="geometry"/>
        </mxCell>
        <mxCell id="m8" value="&quot;I'm lost&quot; → camera wakes → scan 1–2 faces" style="endArrow=block;html=1;fontSize=11;strokeColor=#b85450;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="140" y="670" as="sourcePoint"/><mxPoint x="735" y="670" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m9" value="diff-explain: BFS ≤2 from expected_state, error-model prior (inverted move, wrong face, extra U)" style="endArrow=block;html=1;fontSize=11;strokeColor=#b85450;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="735" y="720" as="sourcePoint"/><mxPoint x="1055" y="720" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m10" value="explained → coach shows undo moves; unexplained → guided repair → partial re-scan (2–3 faces)" style="endArrow=block;html=1;fontSize=11;strokeColor=#b85450;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1055" y="770" as="sourcePoint"/><mxPoint x="425" y="770" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m11" value="last resort: full 6-face re-scan → loadState → one-tap &quot;re-plan from here&quot;" style="endArrow=block;html=1;fontSize=11;strokeColor=#b85450;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="735" y="820" as="sourcePoint"/><mxPoint x="1360" y="820" as="targetPoint"/></mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
