        </mxCell>
        <mxCell id="m8" value="&quot;Next move: R&quot; (StageCaption) · beat advances when history covers it" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1160" y="570" as="sourcePoint"/><mxPoint x="140" y="570" as="targetPoint"/></mxGeometry>
        </mxCell>

        <mxCell id="loop" value="drifted — diff unreachable at max depth" style="rounded=0;whiteSpace=wrap;html=1;fontSize=11;fontStyle=2;verticalAlign=top;align=left;spacing=6;dashed=1;fillColor=none;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="80" y="620" width="1120" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="m9" value="null → drifted" style="endArrow=block;html=1;fontSize=11;strokeColor=#b85450;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="670" y="660" as="sourcePoint"/><mxPoint x="420" y="660" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m10" value="prompt full 6-face re-scan" style="endArrow=block;html=1;fontSize=11;strokeColor=#b85450;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="420" y="710" as="sourcePoint"/><mxPoint x="140" y="710" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m11" value="loadState(new state) → offer re-plan from here / undo my turns" style="endArrow=block;html=1;fontSize=11;strokeColor=#b85450;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="420" y="760" as="sourcePoint"/><mxPoint x="915" y="760" as="targetPoint"/></mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
