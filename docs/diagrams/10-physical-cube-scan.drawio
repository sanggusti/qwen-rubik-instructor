<mxfile host="app.diagrams.net">
  <diagram id="phys-comp" name="Component View">
    <mxGraphModel dx="1000" dy="700" grid="0" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1560" pageHeight="880" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="Physical Cube Play — Camera Scan Pipeline (component view)" style="text;html=1;fontSize=20;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="700" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="user" value="Learner + physical cube" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="70" y="330" width="50" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="browser" value="Browser — SvelteKit frontend (frontend/)" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fontSize=14;fontStyle=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="200" y="90" width="700" height="620" as="geometry"/>
        </mxCell>
        <mxCell id="cam" value="PhysicalCameraWindow&#10;getUserMedia video + 3×3 overlay&#10;(physical/camera.ts)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="browser">
          <mxGeometry x="20" y="50" width="210" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="sampler" value="sampler.ts&#10;frame grab, median inner-ROI per cell" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="browser">
          <mxGeometry x="20" y="150" width="210" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="classify" value="color-classify.ts&#10;RGB→LAB, CIEDE2000 vs 6 center anchors,&#10;k-means over 54, per-sticker confidence" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="browser">
          <mxGeometry x="20" y="240" width="210" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="legal" value="legality.ts&#10;cubie structure · twist ≡0 mod 3 ·&#10;flip ≡0 mod 2 · parity · rotation auto-fix" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="browser">
          <mxGeometry x="20" y="350" width="210" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="fsm" value="physicalStore + scan-machine.ts&#10;idle → scanning(6) → adjust → validating&#10;→ ready → tracking (⟲) → drifted/resync" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#ffffff;strokeColor=#6c8ebf;fontStyle=1;" vertex="1" parent="browser">
          <mxGeometry x="20" y="480" width="210" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="infer" value="infer-moves.ts&#10;canonicalize centers, BFS ≤2(3) over&#10;18+6 moves, expectedMoves tie-break" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="browser">
          <mxGeometry x="290" y="350" width="190" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="cubestore" value="cubeStore&#10;loadState(state) + onLoadState (new)&#10;applyMoves(inferred) → onMove" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#ffffff;strokeColor=#6c8ebf;fontStyle=1;" vertex="1" parent="browser">
          <mxGeometry x="290" y="480" width="190" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="mirror" value="Live cube = read-only mirror&#10;(drag/keys/scramble suppressed&#10;while physicalStore.active)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="browser">
          <mxGeometry x="290" y="240" width="190" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="demo" value="DemoCubeWindow&#10;reference cube — walkthrough&#10;follow-mode playback" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="browser">
          <mxGeometry x="520" y="50" width="160" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="subs" value="Existing subscribers (unchanged)&#10;&#10;lesson coaching (trailingPrefixLength)&#10;walkthrough — new follow mode&#10;review capture (PR #33)&#10;challenge — cancel on loadState" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#ffffff;strokeColor=#6c8ebf;verticalAlign=top;" vertex="1" parent="browser">
          <mxGeometry x="520" y="400" width="160" height="170" as="geometry"/>
        </mxCell>

        <mxCell id="backend" value="FastAPI backend (backend/)" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fontSize=14;fontStyle=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="960" y="90" width="540" height="620" as="geometry"/>
        </mxCell>
        <mxCell id="assist" value="POST /scan/assist (new, only Qwen-VL touchpoint)&#10;low-confidence cells + anchors →&#10;per-cell {color, confidence}, rate-limited" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#ffffff;strokeColor=#9673a6;" vertex="1" parent="backend">
          <mxGeometry x="30" y="60" width="230" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="qwenvl" value="Qwen-VL&#10;qwen3-vl-plus, JSON mode&#10;(DashScope compatible-mode)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="backend">
          <mxGeometry x="320" y="60" width="190" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="legpy" value="pipeline/cube/legality.py (new)&#10;verbatim TS mirror, Node↔Py cross-validated;&#10;hardens /solve + /narrate 4xx" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="backend">
          <mxGeometry x="30" y="220" width="230" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="solveapi" value="POST /solve · /narrate/* (existing)&#10;already accept a full State" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#ffffff;strokeColor=#9673a6;" vertex="1" parent="backend">
          <mxGeometry x="30" y="350" width="230" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="solver" value="LBL solver + planner (existing)&#10;start_from_current=True,&#10;invert(solution) as intro-beat data" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="backend">
          <mxGeometry x="320" y="350" width="190" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="e1" style="endArrow=block;html=1;" edge="1" parent="1" source="user" target="cam">
