        </mxCell>
        <mxCell id="hCoach" value="Coaching / Walkthrough" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fontStyle=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="1080" y="70" width="160" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="hApi" value="/scan/assist → Qwen-VL" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fontStyle=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="1330" y="70" width="160" height="40" as="geometry"/>
