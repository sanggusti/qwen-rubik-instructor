        </mxCell>
        <mxCell id="e15" style="endArrow=block;html=1;" edge="1" parent="backend" source="solveapi" target="solver">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="thesis" value="Thesis: the physical cube is an input device. Two new producers — cubeStore.loadState (scanned State) and synthetic moves from scan-diff inference — feed the two primitives (State + move events) everything downstream already consumes. Vision is client-side; /scan/assist is the only new backend surface." style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="200" y="740" width="700" height="70" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="phys-seq" name="Scan-on-Pause Sequence">
    <mxGraphModel dx="1000" dy="700" grid="0" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1560" pageHeight="880" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

