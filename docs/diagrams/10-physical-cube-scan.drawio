        <mxCell id="lInfer" style="endArrow=none;dashed=1;html=1;strokeColor=#999999;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="670" y="110" as="sourcePoint"/><mxPoint x="670" y="820" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="lStore" style="endArrow=none;dashed=1;html=1;strokeColor=#999999;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="915" y="110" as="sourcePoint"/><mxPoint x="915" y="820" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="lCoach" style="endArrow=none;dashed=1;html=1;strokeColor=#999999;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1160" y="110" as="sourcePoint"/><mxPoint x="1160" y="820" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="lApi" style="endArrow=none;dashed=1;html=1;strokeColor=#999999;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1410" y="110" as="sourcePoint"/><mxPoint x="1410" y="820" as="targetPoint"/></mxGeometry>
        </mxCell>

        <mxCell id="m1" value="turn cube, then hold steady / tap re-scan" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="140" y="150" as="sourcePoint"/><mxPoint x="420" y="150" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m2" value="capture visible face → sample → classify (LAB vs anchors)" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="420" y="200" as="sourcePoint"/><mxPoint x="420" y="230" as="targetPoint"/><Array as="points"><mxPoint x="540" y="200"/><mxPoint x="540" y="230"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="m3" value="low-confidence cells (optional)" style="endArrow=block;html=1;fontSize=11;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="420" y="270" as="sourcePoint"/><mxPoint x="1410" y="270" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m4" value="per-cell {color, confidence}" style="endArrow=block;html=1;fontSize=11;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1410" y="310" as="sourcePoint"/><mxPoint x="420" y="310" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m5" value="prev state + scanned face + expectedNext" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="420" y="360" as="sourcePoint"/><mxPoint x="670" y="360" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="n1" value="canonicalize centers;&#10;BFS depth ≤2 (3 behind flag);&#10;tie-break vs expectedMoves" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="700" y="385" width="170" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="m6" value="inferred moves → applyMoves()" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1">
